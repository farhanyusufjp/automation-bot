# URL website target
BASE_URL=https://your-website.com

# Kredensial login
USERNAME=your_username
PASSWORD=your_password

# Path ke file Excel test case
EXCEL_FILE=test_cases/TEST CASE - Prima Career (SAU).xlsx

# Mode headless browser (true = tidak tampilkan browser, false = tampilkan browser)
HEADLESS=false

# Nama sheet Excel yang ingin dibaca (kosong = sheet pertama)
SHEET_NAME=

# Delay antar aksi dalam millisecond (berguna untuk debug visual, 0 = tanpa delay)
SLOW_MO=500
