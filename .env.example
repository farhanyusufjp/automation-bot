# URL website yang akan ditest
BASE_URL=https://your-website.com

# Kredensial login
USERNAME=your_username
PASSWORD=your_password

# URL halaman login (default: BASE_URL/login)
LOGIN_URL=https://your-website.com/login

# Mode Excel (ikut test case dari file Excel)
EXCEL_FILE=test_cases/TEST CASE - Prima Career (SAU).xlsx

# Mode Explore (test otomatis per halaman)
URLS_FILE=urls.txt

# Pengaturan browser
HEADLESS=false
SLOW_MO=300

# Nama sheet Excel yang dibaca (kosong = sheet pertama)
SHEET_NAME=
